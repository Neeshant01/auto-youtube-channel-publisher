{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and YouTube channel status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo" },
        "youtubeChannelId": { "type": "string", "description": "YouTube Channel ID" },
        "youtubeChannelName": { "type": "string", "description": "YouTube Channel Name" },
        "youtubeChannelPhoto": { "type": "string", "description": "YouTube Channel Profile Image" },
        "channelStatus": { "type": "string", "enum": ["found", "waiting_for_channel", "error"], "description": "Status of YouTube channel detection" },
        "automationMode": { "type": "string", "enum": ["manual", "semi-auto", "full-auto"], "description": "Automation preference" },
        "niche": { "type": "string", "description": "Target niche (e.g., Tech, AI, Finance)" },
        "country": { "type": "string", "description": "Target country" },
        "language": { "type": "string", "description": "Target language" },
        "publishTime": { "type": "string", "description": "Preferred daily publish time (HH:mm)" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last profile update" }
      },
      "required": ["uid", "email"]
    },
    "Trend": {
      "title": "Trend",
      "description": "Daily discovered trending topics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string", "description": "Trending topic title" },
        "description": { "type": "string", "description": "Brief description" },
        "momentum": { "type": "number", "description": "Trend score (0-100)" },
        "category": { "type": "string" },
        "country": { "type": "string" },
        "discoveredAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "selected", "ignored"] }
      },
      "required": ["topic", "momentum"]
    },
    "VideoJob": {
      "title": "VideoJob",
      "description": "A single video generation and publishing pipeline job.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "trendId": { "type": "string" },
        "topic": { "type": "string" },
        "status": { "type": "string", "enum": ["researching", "scripting", "generating_audio", "assembling", "ready_to_publish", "published", "failed"] },
        "pipeline": {
          "type": "object",
          "properties": {
            "research": { "type": "object" },
            "script": { "type": "object" },
            "audioUrl": { "type": "string" },
            "videoUrl": { "type": "string" },
            "thumbnailUrls": { "type": "array", "items": { "type": "string" } },
            "metadata": { "type": "object" }
          }
        },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "youtubeVideoId": { "type": "string" },
        "error": { "type": "string" }
      },
      "required": ["userId", "topic", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/trends": {
      "schema": "Trend",
      "description": "Daily trends"
    },
    "/jobs": {
      "schema": "VideoJob",
      "description": "Video pipeline jobs"
    }
  }
}
